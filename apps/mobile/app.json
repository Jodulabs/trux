{
  "expo": {
    "name": "trux",
    "slug": "trux",
    "scheme": "trux",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trux.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan the QR from `trux pair` to sign into your trux box.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.trux.mobile",
      "permissions": ["android.permission.CAMERA", "android.permission.VIBRATE"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-camera",
        { "cameraPermission": "Scan the QR from `trux pair` to sign into your trux box." }
      ]
    ],
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
